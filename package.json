{
  "server": {
    "name": "PRITESH V5 API",
    "port": "${PORT:3000}",
    "engine": "node>=18.0.0",
    "framework": "express"
  },
  
  "middleware": ["cors", "express.json"],
  
  "api": {
    "baseUrl": "https://draw.ar-lottery01.com/WinGo/WinGo_30S/GetHistoryIssuePage.json",
    "timeout": 5000,
    "headers": {
      "User-Agent": "Mozilla/5.0",
      "Accept": "application/json"
    }
  },

  "endpoints": {
    "/trade": {
      "method": "GET",
      "description": "Get prediction for next round",
      "response": {
        "success": "boolean",
        "data": {
          "period": "string",
          "prediction": "BIG|SMALL|WAITING",
          "confidence": "number (45-95)",
          "numbers": "array[2] of integers",
          "timestamp": "ISO string"
        }
      }
    },
    
    "/result": {
      "method": "POST",
      "description": "Submit actual result to track accuracy",
      "body": {
        "period": "string",
        "actualNumber": "integer 0-9"
      },
      "response": {
        "success": "boolean",
        "data": {
          "isWin": "boolean",
          "winRate": "string (percentage)",
          "total": "integer",
          "wins": "integer"
        }
      }
    },
    
    "/history": {
      "method": "GET",
      "description": "Get last 20 predictions with results",
      "response": {
        "success": "boolean",
        "data": "array of result objects"
      }
    },
    
    "/health": {
      "method": "GET",
      "description": "Server health check",
      "response": {
        "status": "ok",
        "uptime": "seconds",
        "timestamp": "ISO string"
      }
    }
  },

  "predictionLogic": {
    "minDataLength": 5,
    "analysisWindow": 10,
    "recencyWeight": {
      "last3Rounds": 2,
      "others": 1
    },
    "patterns": {
      "mirror": {
        "condition": "alternating BIG/SMALL for 4 rounds",
        "action": "predict opposite of most recent"
      },
      "dragon": {
        "condition": "same BIG/SMALL for 4 rounds", 
        "action": "follow the trend"
      }
    },
    "pivotNumbers": {
      "0": { "next": [5, 7], "reason": "trend reversal to BIG" },
      "5": { "next": [0, 2], "reason": "trend reversal to SMALL" },
      "defaultMap": {
        "1": [6, 2], "2": [7, 0], "3": [8, 1], "4": [9, 2],
        "6": [1, 7], "7": [2, 8], "8": [3, 9], "9": [4, 5]
      }
    },
    "confidenceCalculation": {
      "base": 50,
      "dragonPattern": 90,
      "strongTrend": 76,
      "mirrorPattern": 65,
      "frequencyBonus": "±8 per deviation from 3/6",
      "volatilityPenalty": "-5 per high-variance jump",
      "bounds": [45, 95]
    }
  },

  "responseSchema": {
    "trade": {
      "success": true,
      "data": {
        "period": "20240417001234",
        "prediction": "BIG",
        "confidence": 76.5,
        "numbers": [2, 8],
        "timestamp": "2024-04-17T10:30:45.123Z",
        "meta": {
          "pattern": "dragon",
          "lastNumber": 4,
          "trend": "BIG"
        }
      }
    },
    "error": {
      "success": false,
      "error": {
        "code": "API_ERROR|INVALID_INPUT|SERVER_ERROR",
        "message": "Human readable error"
      }
    }
  },

  "polling": {
    "interval": 1000,
    "retryDelay": 2000,
    "maxRetries": 3
  },

  "tracking": {
    "maxHistory": 20,
    "winCondition": "categoryMatch OR numberMatch"
  }
}
