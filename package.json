const express = require("express");
const axios = require("axios");

const app = express();
const PORT = process.env.PORT || 3000;

// Configuration
const API_URL = "https://draw.ar-lottery01.com/WinGo/WinGo_30S/GetHistoryIssuePage.json";

// Prediction Logic Function
const getNeuralPrediction = (data) => {
    if (!data || data.length < 5) return { cat: "BIG", nums: [1, 6] };

    // Weighted Trend Analysis
    let bigWeight = 0;
    let smallWeight = 0;
    data.slice(0, 10).forEach((item, i) => {
        const num = parseInt(item.number);
        const weight = i < 3 ? 3.0 : 1.0; // Latest 3 rounds have 3x impact
        if (num >= 5) bigWeight += weight;
        else smallWeight += weight;
    });

    const predCat = bigWeight >= smallWeight ? "BIG" : "SMALL";

    // Opposite Number Mapping (Winning Strategy)
    const lastNum = parseInt(data[0].number);
    const oppMap = {
        0:[5,8], 1:[6,9], 2:[0,8], 3:[1,7], 4:[2,6],
        5:[0,3], 6:[1,4], 7:[2,5], 8:[3,6], 9:[4,7]
    };
    const picks = oppMap[lastNum] || [1, 6];

    return { category: predCat, numbers: picks };
};

// API Endpoint
app.get("/api", async (req, res) => {
    try {
        const response = await axios.get(`${API_URL}?ts=${Date.now()}`);
        const list = response.data.data.list;

        if (!list) throw new Error("API Data unreachable");

        const currentIssue = list[0].issue;
        const prediction = getNeuralPrediction(list);
        const nextPeriod = (parseInt(currentIssue) + 1).toString();

        res.json({
            success: true,
            next_period: nextPeriod,
            prediction: prediction.category,
            recommended_numbers: prediction.numbers,
            last_result: {
                period: currentIssue,
                number: list[0].number
            }
        });
    } catch (error) {
        res.status(500).json({ success: false, message: error.message });
    }
});

app.get("/", (req, res) => {
    res.send("API IS RUNNING. Use /api for predictions.");
});

app.listen(PORT, () => {
    console.log(`Server started on port ${PORT}`);
});
